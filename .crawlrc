# Documentation
#   https://raw.githubusercontent.com/crawl/crawl/master/crawl-ref/docs/options_guide.txt
#   https://github.com/crawl/crawl/blob/73021bd113/crawl-ref/docs/keybind.txt



# ----- Options ----------------------------------------------------------------
# ------------------------------------------------------------------------------

# ----- Visual -----------------------------------------------------------------

# Use glyphs even in tile version.
tile_display_mode = glyphs

# Use proper wall chars instead of '#', among others.
# Note: Halfs colours (RBG values) for █.
# Note: Changes more than just walls.
include = ibm_glyphs.txt

# Undo some of the alternatives from ibm_glyphs.
display_char = door_closed:+
display_char = altar:_

# Alternative for proper walls instead of '#'
#   -> this uses normal colours, instead of RBG halfed.
# display_char = wall:█

# Use ~ for missiles.
display_char = item_missile:~

# Custom colours.
message_colour += yellow:You are too injured to fight recklessly!
feature += travel trail {,,lightgrey} # Do not overwrite actual symbol, only BG colour.

# Width of the map view.
view_max_width = 81

# Height of the map view vs. message area.
view_max_height = 71
msg_min_height = 5
msg_max_height = 5

# Bright yellow @ on black (default-ish)
mon_glyph += player : white
use_fake_player_cursor = true

# Turn on the full spell menu on z.
spell_menu = true

# ----- Exploration Options ----------------------------------------------------

rest_delay = -1
travel_delay = -1
# Optional: Small delay for auto explore only to move stepwise.
explore_delay = -1

# Stop on these things, do not open doors.
explore_stop += greedy_pickup,stairs,shops,altars,portals,branches,runed_doors
travel_open_doors = false

# Show a grey trail of '·'.
# { <symbol>, <magicmap symbol>, <view colour>,
#   <levelmap_magic_colour>, <levelmap_seen_colour>,
#   <emphasised_colour>, <levelmap_emphasised_colour>
# Colours: 
#  black,    blue,      green,      cyan,      red,      magenta,      brown,  lightgrey, 
#  darkgrey, lightblue, lightgreen, lightcyan, lightred, lightmagenta, yellow, white
show_travel_trail = true

# ----- Gameplay Options -------------------------------------------------------

# Stop 'tab' fighting on 80% HP.
autofight_stop = 80

# Get a <more> warning at 66% HP.
hp_warning = 66

# Rest before auto-exploring with 'o'.
explore_auto_rest = true

# Rest to '100%' HP/MP.
rest_wait_percent = 100

# Print all lines in Log (most of the time).
show_more = false

# Set training to manual by default.
default_manual_training = true



# ----- Keybindings ------------------------------------------------------------
# ------------------------------------------------------------------------------

# Uses YU HJKL NM, rebinding bB for skills and spells (in place of mM)

bindkey = [m] CMD_MOVE_DOWN_RIGHT
bindkey = [n] CMD_MOVE_DOWN_LEFT
bindkey = [b] CMD_DISPLAY_SKILLS

bindkey = [M] CMD_RUN_DOWN_RIGHT
bindkey = [N] CMD_RUN_DOWN_LEFT
bindkey = [B] CMD_MEMORISE_SPELL

bindkey = [^M] CMD_ATTACK_DOWN_RIGHT
bindkey = [^N] CMD_ATTACK_DOWN_LEFT

bindkey = [m] CMD_TARGET_DOWN_RIGHT
bindkey = [n] CMD_TARGET_DOWN_LEFT
bindkey = [M] CMD_TARGET_DIR_DOWN_RIGHT
bindkey = [N] CMD_TARGET_DIR_DOWN_LEFT

bindkey = [m] CMD_MAP_MOVE_DOWN_RIGHT
bindkey = [n] CMD_MAP_MOVE_DOWN_LEFT
bindkey = [M] CMD_MAP_JUMP_DOWN_RIGHT
bindkey = [N] CMD_MAP_JUMP_DOWN_LEFT



# ----- LUA --------------------------------------------------------------------
# ------------------------------------------------------------------------------

# ----- Slow and fast explorew -------------------------------------------------
#
# Functions that automatically set the explore_delay to either a medium bumber
# (slow explore, bound do O) or off (fast explore, o).
# Thus, using O enables a stepwise observable outexplore.

macros += M O ===slow_explore
macros += M o ===fast_explore
{
    function slow_explore()
        crawl.setopt("explore_delay = 150")
        crawl.process_keys("o")
    end
    
    function fast_explore()
        crawl.setopt("explore_delay = -1")
        crawl.process_keys("o")
    end
}

